# Supabase — get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://psqkownzvbipxzvjlmbc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to browser

# Mapbox — get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Email — get from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Feature flags (false = feature hidden in UI, schema always present)
NEXT_PUBLIC_INTERNATIONAL_ENABLED=false
NEXT_PUBLIC_WHATSAPP_ENABLED=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
